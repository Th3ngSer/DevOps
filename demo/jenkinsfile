pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                git branch: 'DevOps_Exam', url: 'https://github.com/yourusername/your-private-repo.git                '
            }
        }
        stage('Build') {
            steps {
                // If using Gradle:
                sh './gradlew build'
            }
        }
    }
    
    post {
        failure {
            emailext (
                subject: "SpringBoot-Project-PangLythong - Build Failed",
                body: "Build #${env.BUILD_NUMBER} failed.\n\nCheck the console output for the error stacktrace here: ${env.BUILD_URL}",
                to: "your.target.email@gmail.com"
            )
        }
        success {
            emailext (
                subject: "SpringBoot-Project-PangLythong - Build Successful",
                body: "Build #${env.BUILD_NUMBER} completed successfully.\n\nView build details here: ${env.BUILD_URL}",
                to: "your.target.email@gmail.com"
            )
        }
    }
}