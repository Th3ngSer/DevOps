pipeline {
    agent any
    
    tools {
        maven 'Maven3'
        jdk 'JDK25'  // If you have JDK configured in Jenkins
    }
    
    stages {
        stage('Fix Java Version') {
            steps {
                sh '''
                    # Override Java version in pom.xml
                    sed -i 's/25/17/g' pom.xml
                '''
            }
        }
        
        stage('Build') {
            steps {
                sh 'mvn clean install -Dmaven.compiler.release=17'
            }
        }
    }
    
    post {
        success {
            echo 'Build successful!'
        }
        failure {
            echo 'Build failed!'
            emailext (
                to: 'akainusan555@gmail.com',
                subject: "Build Failed: ${env.JOB_NAME} - ${env.BUILD_NUMBER}",
                body: "Check the build logs at ${env.BUILD_URL}"
            )
        }
    }
}